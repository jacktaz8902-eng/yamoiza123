<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADKAR 기반 조직변화 페인포인트 사전진단</title>
    <style>
        :root {
            --primary-color: #4A90E2;
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-muted: #666666;
        }

        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-main);
            line-height: 1.6;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: var(--card-bg);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px;
        }

        h1 {
            text-align: center;
            color: var(--primary-color);
            font-size: 24px;
            margin-bottom: 10px;
        }

        .notice {
            background-color: #f8f9fa;
            border-left: 4px solid var(--primary-color);
            padding: 15px;
            margin-bottom: 30px;
            border-radius: 4px;
            font-size: 14px;
            color: var(--text-muted);
        }

        .user-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #eee;
        }

        input[type="text"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 14px;
        }

        .question-card {
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
            transition: transform 0.2s;
        }

        .question-card:hover {
            transform: translateY(-2px);
            border-color: var(--primary-color);
        }

        .category-badge {
            display: inline-block;
            background: #e3f2fd;
            color: #1976d2;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .question-text {
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .scale-group {
            display: flex;
            justify-content: space-between;
            gap: 10px;
        }

        .scale-option {
            flex: 1;
            text-align: center;
        }

        .scale-option input[type="radio"] {
            display: none;
        }

        .scale-option label {
            display: block;
            padding: 10px 5px;
            background: #f8f9fa;
            border: 1px solid #ddd;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }

        .scale-option input[type="radio"]:checked + label {
            background: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
            font-weight: bold;
        }

        textarea {
            width: 100%;
            height: 100px;
            padding: 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-sizing: border-box;
            resize: vertical;
            font-family: inherit;
        }

        .submit-btn {
            display: block;
            width: 100%;
            padding: 15px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 40px;
            transition: background 0.3s;
        }

        .submit-btn:hover {
            background: #357abd;
        }

        @media (max-width: 600px) {
            .scale-group {
                flex-direction: column;
            }
            .container { padding: 20px; }
        }
    </style>
</head>
<body>

<div class="container">
    <h1>ADKAR 기반 조직변화 페인포인트 사전진단</h1>
    
    <div class="notice">
        <strong>안내사항</strong><br>
        본 설문은 조직변화 추진 전 구성원의 변화 준비상태와 주요 페인포인트(장애요인)를 파악하기 위한 목적입니다.<br>
        응답해주신 내용은 철저히 익명으로 보장되며, 통계적 목적으로만 활용됩니다. 솔직하게 응답해 주시기 바랍니다.
    </div>

    <div class="user-info">
        <div><label>소속</label><input type="text" placeholder="예: 기획팀"></div>
        <div><label>직위/직급</label><input type="text" placeholder="예: 팀장"></div>
        <div><label>근속연수</label><input type="text" placeholder="예: 5년"></div>
        <div><label>성명 (선택)</label><input type="text" placeholder="선택사항"></div>
    </div>

    <form id="surveyForm">
        <div id="questionsContainer"></div>

        <div class="question-card">
            <div class="category-badge">서술형 의견</div>
            <div class="question-text">1. 현재 우리 조직이 변화를 추진하는 데 있어 가장 우려되는 장애요인(페인포인트)은 무엇입니까?</div>
            <textarea placeholder="자유롭게 작성해주세요."></textarea>
        </div>

        <div class="question-card">
            <div class="category-badge">서술형 의견</div>
            <div class="question-text">2. 성공적인 변화 안착을 위해 회사나 부서 차원에서 가장 필요하다고 생각하는 지원은 무엇입니까?</div>
            <textarea placeholder="자유롭게 작성해주세요."></textarea>
        </div>
        
        <div class="question-card">
            <div class="category-badge">서술형 의견</div>
            <div class="question-text">3. 기타 변화관리와 관련된 건의사항이나 자유로운 의견을 적어 주십시오.</div>
            <textarea placeholder="자유롭게 작성해주세요."></textarea>
        </div>

        <button type="button" class="submit-btn" onclick="alert('제출이 완료되었습니다. (백엔드 연결 필요)')">설문 제출하기</button>
    </form>
</div>

<script>
    const questions = [
        { category: "인지 (Awareness)", text: "나는 현재 우리 조직이 왜 변화해야 하는지 그 필요성과 배경을 명확히 이해하고 있다." },
        { category: "인지 (Awareness)", text: "나는 이번 변화를 추진하지 않았을 때 발생할 수 있는 조직의 위기나 문제점에 대해 공감한다." },
        { category: "인지 (Awareness)", text: "이번 변화가 궁극적으로 우리 조직이 나아가야 할 올바른 비전과 방향이라고 생각한다." },
        { category: "인지 (Awareness)", text: "나는 이번 변화가 나의 현재 업무, 역할, 부서에 구체적으로 어떤 영향을 미치는지 알고 있다." },
        { category: "의지 (Desire)", text: "나는 이번 조직변화 과정에 수동적으로 끌려가지 않고 적극적으로 참여할 의지가 있다." },
        { category: "의지 (Desire)", text: "나의 직속 상사 및 경영진은 이번 변화를 적극적으로 지지하고 후원하는 모습을 보여준다." },
        { category: "의지 (Desire)", text: "나는 이번 변화가 장기적으로 나의 개인적인 성장이나 업무 환경 개선에 도움이 될 것이라 기대한다." },
        { category: "의지 (Desire)", text: "우리 부서(팀) 동료들은 전반적으로 이번 변화에 대해 긍정적이며 서로 협력하려는 분위기이다." },
        { category: "지식 (Knowledge)", text: "나는 변화된 환경이나 새로운 프로세스 하에서 내게 요구되는 새로운 역할과 책임을 명확히 알고 있다." },
        { category: "지식 (Knowledge)", text: "나는 새로운 업무 방식, 시스템, 프로세스를 수행하는 데 필요한 실무적 지식을 충분히 갖추고 있다." },
        { category: "지식 (Knowledge)", text: "조직은 변화를 이해하고 적응하는 데 필요한 사전 교육, 안내 자료, 매뉴얼을 충분히 제공하고 있다." },
        { category: "지식 (Knowledge)", text: "나는 변화 실행 과정에서 궁금한 점이 생기거나 문제가 발생했을 때 누구에게 문의하고 도움을 받아야 하는지 알고 있다." },
        { category: "실행 (Ability)", text: "나는 교육받은 새로운 지식과 기술을 실제 나의 현업에 무리 없이 적용하고 수행할 능력이 있다." },
        { category: "실행 (Ability)", text: "현재 우리 조직의 시스템, IT 인프라, 업무 환경은 새로운 방식으로 일하는 것을 구조적으로 잘 지원하고 있다." },
        { category: "실행 (Ability)", text: "기존의 복잡한 결재 절차, 구시대적 규정, 부서 간 장벽 등이 새로운 변화를 실행하는 데 방해가 되지 않는다." },
        { category: "실행 (Ability)", text: "새로운 변화를 현업에 안착시키고 실행하는 데 필요한 시간, 인력, 예산 등의 물리적 자원이 충분히 주어지고 있다." },
        { category: "강화 (Reinforcement)", text: "새로운 방식에 맞게 행동하고 성과를 내었을 때, 조직 차원에서 적절한 보상과 인정이 이루어질 것이라 믿는다." },
        { category: "강화 (Reinforcement)", text: "우리 조직의 인사 평가 제도나 KPI는 새로운 변화의 목적 및 행동 양식과 어긋나지 않고 잘 정렬되어 있다." },
        { category: "강화 (Reinforcement)", text: "리더들은 변화 추진이 일회성 이벤트에 그치지 않도록 현장의 실행 여부를 지속적으로 점검하고 독려한다." },
        { category: "강화 (Reinforcement)", text: "나는 이번 변화가 일시적인 캠페인으로 끝나지 않고 우리 조직의 당연한 일하는 방식과 문화로 굳어질 것이라 생각한다." }
    ];

    const labels = ["1점<br>(전혀 아니다)", "2점<br>(아닌 편이다)", "3점<br>(보통이다)", "4점<br>(그런 편이다)", "5점<br>(매우 그렇다)"];
    const container = document.getElementById('questionsContainer');

    questions.forEach((q, index) => {
        const qNum = index + 1;
        let scaleHTML = '';
        
        for(let i=1; i<=5; i++) {
            scaleHTML += `
                <div class="scale-option">
                    <input type="radio" id="q${qNum}_${i}" name="q${qNum}" value="${i}">
                    <label for="q${qNum}_${i}">${labels[i-1]}</label>
                </div>
            `;
        }

        const cardHTML = `
            <div class="question-card">
                <div class="category-badge">${q.category}</div>
                <div class="question-text">${qNum}. ${q.text}</div>
                <div class="scale-group">
                    ${scaleHTML}
                </div>
            </div>
        `;
        container.innerHTML += cardHTML;
    });
</script>

</body>
</html>
